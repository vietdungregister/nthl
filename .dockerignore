# ============================================================
# .dockerignore — Loại bỏ các file/thư mục không cần thiết
# khi Docker copy context vào image, giúp build nhanh hơn
# và tránh rò rỉ thông tin nhạy cảm.
# ============================================================


# --- Version Control ---
.git
.gitignore


# --- Environment Variables (BẮT BUỘC loại bỏ, CỰC KỲ NHẠY CẢM) ---
.env
.env.local
.env.*.local
.env.development
.env.production


# --- Large data folders (media, FB export, uploads) ---
/media/
/output/
/data/
/facebook-nguyenthehoanglinh-06_03_2026-y1cYzpJi/
/public/uploads/fb/
*.dump
*.tar.gz


# --- Next.js cache & build output (sẽ được build lại trong container) ---
.next
out


# --- Node modules (sẽ được cài lại bằng npm ci trong container) ---
node_modules


# --- Database file SQLite (dùng cho dev, không đưa vào Docker) ---
dev.db
prisma/dev.db
*.db
*.sqlite


# --- Log files ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# --- Editor & IDE configs ---
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln


# --- OS generated files ---
.DS_Store
Thumbs.db


# --- CI/CD & Documentation (không cần trong runtime image) ---
.claude
.agents
.github
README.md
IMPLEMENTATION_PLAN.md
CLAUDE.md
*.md


# --- Test & Dev scripts (không cần trong production) ---
scripts/health-check.js
scripts/check-db.ts
scripts/update-admin-password.ts
scripts/update-db.ts
scripts/build-data.py
scripts/export-to-docx.py
scripts/deploy-init.sh
scripts/server-deploy.sh
scripts/check-genres.js
scripts/fix-genre-prose.js
scripts/fix-genre-duplicates.js


# --- TypeScript build info cache ---
tsconfig.tsbuildinfo


# --- Prisma seed files (chỉ dùng khi setup lần đầu, không cần trong image) ---
prisma/seed.ts
prisma/seed-genres.js

