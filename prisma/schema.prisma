generator client {
  provider      = "prisma-client-js"
  // native: dùng khi dev trên Mac/Windows
  // linux-musl-openssl-3.0.x: dùng khi chạy trong Docker container (node:20-alpine)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model AdminUser {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  createdAt      DateTime  @default(now())
  lastLoginAt    DateTime?
  loginAttempts  Int       @default(0)
  lockUntil      DateTime?
}


model Work {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  genre          String
  content        String
  excerpt        String?
  coverImageUrl  String?

  status         String   @default("draft")
  publishedAt    DateTime?
  scheduledAt    DateTime?

  isFeatured     Boolean  @default(false)
  featuredDate   DateTime?

  // Ngày tác giả sáng tác (optional, khác publishedAt)
  writtenAt      DateTime?
  // Bản dịch & ghi chú bổ sung — lưu JSON: [{ lang, title?, content, note? }]
  translations   String?

  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?

  viewCount      Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  tags           WorkTag[]
  collections    WorkCollection[]
  comments       Comment[]
  chunks         ChatChunk[]

  // Metadata từ Facebook import
  source         String?                 // "facebook" | null
  fbTimestamp    Int?                    // unix timestamp gốc
  autoClassified Boolean  @default(false) // do AI phân loại tự động

  // Performance indexes cho các query phổ biến
  // [status, deletedAt, publishedAt] → filter published + sort theo ngày (trang chủ, danh sách)
  @@index([status, deletedAt, publishedAt(sort: Desc)])
  // [genre, status, deletedAt] → filter theo thể loại
  @@index([genre, status, deletedAt])
  // [featuredDate, status, deletedAt] → tìm tác phẩm được ghim theo ngày (trang chủ)
  @@index([featuredDate, status, deletedAt])
  // [createdAt] → sort theo ngày tạo trong CMS dashboard
  @@index([createdAt(sort: Desc)])
  // [deletedAt, status] → dashboard COUNT queries
  @@index([deletedAt, status])
}

model Comment {
  id        String   @id @default(uuid())
  workId    String
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  name      String
  content   String
  createdAt DateTime @default(now())
}

model Tag {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  works WorkTag[]
}

model Collection {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  works       WorkCollection[]
}

model WorkTag {
  work   Work   @relation(fields: [workId], references: [id], onDelete: Cascade)
  workId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([workId, tagId])
}

model WorkCollection {
  work         Work       @relation(fields: [workId], references: [id], onDelete: Cascade)
  workId       String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String

  @@id([workId, collectionId])
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  type      String
  size      Int
  width     Int?
  height    Int?
  altText   String?
  createdAt DateTime @default(now())
}

model AuthorProfile {
  id            String @id @default("singleton")
  name          String @default("Nguyễn Thế Hoàng Linh")
  bio           String @default("")
  bioShort      String @default("")
  avatarUrl     String @default("")
  coverImageUrl String @default("")
  socialLinks   String @default("{}")
  awards        String @default("[]")
  publications  String @default("[]")
}

model Genre {
  id            String  @id @default(uuid())
  value         String  @unique
  label         String
  emoji         String  @default("📝")
  order         Int     @default(0)
  showInSidebar Boolean @default(true)
}

model Book {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  buyUrl      String?
  publisher   String?
  year        Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Chatbot "Thơ Máy" ──────────────────────────────────────────────────────

/// Chunk 1-2 dòng của tác phẩm, dùng cho chatbot trả về gợi ý ngẫu nhiên
model ChatChunk {
  id        String   @id @default(uuid())
  workId    String
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  content   String                      // 1-2 dòng text
  // embedding: vector(3072) — lưu thủ công qua raw SQL vì Prisma chưa hỗ trợ pgvector
  score     Float    @default(0)        // tích lũy từ feedback: 👍 +1, 👎 -1
  isBlocked Boolean  @default(false)   // tác giả block vĩnh viễn

  createdAt DateTime @default(now())

  feedbacks ChatFeedback[]

  @@index([workId])
  @@index([isBlocked, score(sort: Desc)])
}

/// Feedback từ user hoặc tác giả sau mỗi lần chatbot trả kết quả
model ChatFeedback {
  id       String    @id @default(uuid())
  chunkId  String
  chunk    ChatChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  query    String                        // user gõ gì
  rating   Int                           // +1 (👍) hoặc -1 (👎)
  isAuthor Boolean   @default(false)    // tác giả feedback → weight ×3

  createdAt DateTime @default(now())

  @@index([chunkId])
  @@index([createdAt(sort: Desc)])
}

/// Quy tắc tác giả dạy AI — Tầng 1 (Form) hoặc Tầng 2 (AI parse)
model AuthorInstruction {
  id          String   @id @default(uuid())
  type        String                    // "correction" | "rule" | "reclassify"
  query       String?                   // trigger keyword
  badChunkId  String?                   // chunk bị sửa
  goodChunkId String?                   // chunk thay thế
  instruction String                    // text gốc tác giả gõ (Tầng 2)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  @@index([isActive, query])
}

/// Bộ nhớ dài hạn AI — tác giả dạy AI hiểu phong cách, triết lý, preference
model AuthorMemory {
  id        String   @id @default(uuid())
  content   String                      // "Tác giả thích giọng hài hước, triết lý nhẹ"
  category  String                      // "style" | "preference" | "philosophy" | "rule"
  source    String                      // "chat" | "feedback" | "manual"

  createdAt DateTime @default(now())

  @@index([category])
}

